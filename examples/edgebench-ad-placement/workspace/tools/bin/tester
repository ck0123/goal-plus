#!/usr/bin/env python3
from __future__ import annotations

import math
import sys
from pathlib import Path


GRID_SIZE = 10_000


def fail(message: str) -> int:
    print(f"Invalid: {message}", file=sys.stderr)
    return 1


def read_ints(path: Path) -> list[int]:
    try:
        return [int(token) for token in path.read_text(encoding="utf-8").split()]
    except (OSError, ValueError) as exc:
        raise ValueError(f"cannot parse {path}: {exc}") from exc


def overlaps(left: tuple[int, int, int, int], right: tuple[int, int, int, int]) -> bool:
    return (
        max(left[0], right[0]) < min(left[2], right[2])
        and max(left[1], right[1]) < min(left[3], right[3])
    )


def main() -> int:
    if len(sys.argv) != 3:
        print("usage: tester INPUT OUTPUT", file=sys.stderr)
        return 2

    try:
        input_values = read_ints(Path(sys.argv[1]))
        output_values = read_ints(Path(sys.argv[2]))
    except ValueError as exc:
        return fail(str(exc))

    if not input_values:
        return fail("empty input")
    n = input_values[0]
    if n <= 0 or len(input_values) != 1 + 3 * n:
        return fail("input does not contain n followed by n x/y/r triples")
    if len(output_values) != 4 * n:
        return fail(f"expected {n} rectangles, got {len(output_values) // 4}")

    ads = [tuple(input_values[1 + 3 * i : 4 + 3 * i]) for i in range(n)]
    rectangles = [tuple(output_values[4 * i : 4 * i + 4]) for i in range(n)]
    satisfaction_sum = 0.0

    for index, ((x, y, target), (x1, y1, x2, y2)) in enumerate(zip(ads, rectangles)):
        if not (0 <= x1 < x2 <= GRID_SIZE and 0 <= y1 < y2 <= GRID_SIZE):
            return fail(f"rectangle {index} is empty or outside the grid")
        if not (x1 <= x < x2 and y1 <= y < y2):
            return fail(f"rectangle {index} does not contain its anchor")
        area = (x2 - x1) * (y2 - y1)
        ratio = min(area, target) / max(area, target)
        satisfaction_sum += 1.0 - (1.0 - ratio) ** 2

    for left in range(n):
        for right in range(left + 1, n):
            if overlaps(rectangles[left], rectangles[right]):
                return fail(f"rectangles {left} and {right} overlap")

    score = math.floor(1_000_000_000 * satisfaction_sum / n + 0.5)
    print(f"Score = {score}", file=sys.stderr)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
