#!/usr/bin/env python3
from __future__ import annotations

import argparse
import math
import random
from pathlib import Path


GRID_SIZE = 10_000
ADS_PER_CASE = 200


def generate(seed: int) -> list[tuple[int, int, int]]:
    rng = random.Random(seed)
    anchors: set[tuple[int, int]] = set()
    ads: list[tuple[int, int, int]] = []
    while len(ads) < ADS_PER_CASE:
        x = rng.randrange(GRID_SIZE)
        y = rng.randrange(GRID_SIZE)
        if (x, y) in anchors:
            continue
        anchors.add((x, y))
        target_area = min(
            GRID_SIZE * GRID_SIZE,
            max(1, int(math.exp(rng.uniform(math.log(100), math.log(2_000_000))))),
        )
        ads.append((x, y, target_area))
    return ads


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Generate EdgeBench-format ad-placement inputs from a seed file."
    )
    parser.add_argument("seed_file", type=Path)
    parser.add_argument("-d", "--output-dir", type=Path, required=True)
    args = parser.parse_args()

    seeds = [
        int(line.strip())
        for line in args.seed_file.read_text(encoding="utf-8").splitlines()
        if line.strip()
    ]
    if not seeds:
        parser.error("seed file must contain at least one integer seed")

    args.output_dir.mkdir(parents=True, exist_ok=True)
    for index, seed in enumerate(seeds):
        ads = generate(seed)
        output = args.output_dir / f"{index:04d}.txt"
        lines = [str(len(ads)), *(f"{x} {y} {target}" for x, y, target in ads)]
        output.write_text("\n".join(lines) + "\n", encoding="utf-8")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
