{
  "objective": "maximize k-module pipeline configuration score with AdaptEvolve worker-tier routing",
  "metric_name": "combined_score",
  "metric_direction": "maximize",
  "source_path": "tests/fixtures/k_module_problem",
  "edit_surface": {
    "allow": [
      "initial_program.py"
    ],
    "deny": [
      "evaluator.py",
      "config.yaml"
    ]
  },
  "process_verifiers": [
    {
      "name": "k_module_score",
      "role": "ranking_signal",
      "command": [
        "python",
        "-c",
        "from evaluator import evaluate; import json; print(json.dumps(evaluate('initial_program.py'), sort_keys=True))"
      ],
      "timeout_seconds": 30
    }
  ],
  "promotion_verifiers": [
    {
      "name": "evaluator_hash_check",
      "role": "anti_cheat_gate",
      "command": [
        "search-runtime-internal",
        "check-frozen-hashes"
      ]
    }
  ],
  "budget": {
    "max_candidates": 1,
    "max_parallel": 1
  },
  "strategy": {
    "name": "adaptevolve",
    "driver": "python",
    "ref": "agentic_any_search_mcp.strategies.adaptevolve:AdaptEvolveStrategy",
    "worker_mode": "agent-session-pool",
    "worker_agent_type": "AnySearchAgentFlash",
    "history_policy": {
      "scope": "top_n",
      "top_n": 5
    },
    "config": {
      "tiers": [
        "AnySearchAgentFlash",
        "AnySearchAgent",
        "AnySearchAgentDeep",
        "AnySearchAgentExtraDeep"
      ],
      "low_score_threshold": 0.2,
      "high_score_threshold": 0.8
    }
  },
  "root_hypotheses": [
    "baseline",
    "fix loader",
    "fix loader and preprocess",
    "full target"
  ]
}
