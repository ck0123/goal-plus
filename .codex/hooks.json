{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "goal-plus --goal-plus-host-hook",
            "timeout": 30,
            "statusMessage": "Preparing Goal Plus context"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "goal-plus --goal-plus-host-hook",
            "timeout": 30,
            "statusMessage": "Restoring Goal Plus context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "goal-plus --goal-plus-host-hook",
            "timeout": 30,
            "statusMessage": "Checking Goal Plus tool gate"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "goal-plus --goal-plus-host-hook",
            "timeout": 30,
            "statusMessage": "Checking Goal Plus post-tool actions"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "goal-plus --goal-plus-host-hook",
            "timeout": 30,
            "statusMessage": "Checking Goal Plus stop gate"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "goal-plus --goal-plus-host-hook",
            "timeout": 30,
            "statusMessage": "Checking Goal Plus subagent gate"
          }
        ]
      }
    ]
  }
}
